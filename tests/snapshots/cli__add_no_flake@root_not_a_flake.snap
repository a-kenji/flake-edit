---
source: tests/cli.rs
info:
  program: flake-edit
  args:
    - "--flake"
    - "[FIXTURES]/root.flake.nix"
    - "--diff"
    - add
    - "--no-flake"
    - not_a_flake
    - "github:a-kenji/not_a_flake"
  env:
    NO_COLOR: "1"
---
success: true
exit_code: 0
