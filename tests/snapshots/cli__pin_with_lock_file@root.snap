---
source: tests/cli.rs
info:
  program: flake-edit
  args:
    - "--flake"
    - "[FIXTURES]/root.flake.nix"
    - "--lock-file"
    - "[FIXTURES]/root.flake.lock"
    - "--diff"
    - pin
    - nixpkgs
  env:
    NO_COLOR: "1"
---
success: true
exit_code: 0
