---
source: tests/cli.rs
info:
  program: flake-edit
  args:
    - "--flake"
    - "[FIXTURES]/toggle_flat.flake.nix"
    - "--diff"
    - toggle
    - rust-overlay
    - "git+https://example.org/forks/rust-overlay"
  env:
    NO_COLOR: "1"
---
success: true
exit_code: 0
