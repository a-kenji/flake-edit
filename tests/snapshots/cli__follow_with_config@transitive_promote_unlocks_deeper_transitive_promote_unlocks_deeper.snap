---
source: tests/cli.rs
info:
  program: flake-edit
  args:
    - "--flake"
    - "[FIXTURES]/transitive_promote_unlocks_deeper.flake.nix"
    - "--lock-file"
    - "[FIXTURES]/transitive_promote_unlocks_deeper.flake.lock"
    - "--config"
    - "[FIXTURES]/transitive_promote_unlocks_deeper.config.toml"
    - "--diff"
    - follow
  env:
    NO_COLOR: "1"
---
success: true
exit_code: 0
