   inputs.crane.url = "github:ipetkov/crane";
-  inputs.crane.inputs.nixpkgs.follows = "nixpkgs-stable";
+  inputs.crane.inputs.nixpkgs.follows = "nixpkgs";

   outputs = _: { };
