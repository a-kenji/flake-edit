--- original
+++ modified
@@ -2,8 +2,7 @@
   description = "leading comma outputs";

   outputs =
-    { nixpkgs-unstable
-    , pre-commit-nix
+    { pre-commit-nix
     , ...
     }:
     {
@@ -10,7 +9,6 @@
     };

   inputs = {
-    nixpkgs-unstable.url = "github:NixOS/nixpkgs/nixpkgs-unstable";
     pre-commit-nix.url = "github:cachix/pre-commit-hooks.nix";
   };
 }

