---
source: tests/cli.rs
info:
  program: flake-edit
  args:
    - "--flake"
    - "[FIXTURES]/outputs_leading_comma_remove_first.flake.nix"
    - "--diff"
    - rm
    - nixpkgs-unstable
  env:
    NO_COLOR: "1"
---
success: true
exit_code: 0
