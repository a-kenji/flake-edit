     treefmt.url = "github:numtide/treefmt";
+    treefmt.inputs.nixpkgs.follows = "nixpkgs";
+    treefmt.inputs.treefmt-nix.follows = "treefmt-nix";
+    nixpkgs.url = "github:nixos/nixpkgs/nixos-unstable";
   };

   outputs =
@@ -11,6 +15,7 @@
       self,
       treefmt-nix,
       treefmt,
+      nixpkgs,
     }:
     { };
 }

