---
source: tests/cli.rs
info:
  program: flake-edit
  args:
    - "--flake"
    - "[FIXTURES]/treefmt_transitive.flake.nix"
    - "--lock-file"
    - "[FIXTURES]/treefmt_transitive.flake.lock"
    - "--diff"
    - follow
    - "--transitive"
    - "2"
  env:
    NO_COLOR: "1"
---
success: true
exit_code: 0
