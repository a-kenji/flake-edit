---
source: tests/cli.rs
info:
  program: flake-edit
  args:
    - "--flake"
    - "[FIXTURES]/root.flake.nix"
    - "--diff"
    - add
    - "--shallow"
    - shallow_input
    - "github:foo/bar"
  env:
    NO_COLOR: "1"
---
success: true
exit_code: 0
